---
const {content} = Astro.props;
---
<style>
  @reference "../styles/app.css";

  .content-area {
    @apply text-xl leading-9;

    p {
      @apply mb-2 lg:mb-4
    }

    h1 {
      @apply heading-1;
    }

    h2 {
      @apply heading-2;
    }

    h3 {
      @apply heading-3;
    }

    h4 {
      @apply heading-4;
    }

    h5 {
      @apply heading-5;
    }

    h6 {
      @apply heading-6;
    }

    ul {
      @apply list-disc;
    }

    ol {
      @apply list-decimal;
    }

    ul, ol {
      @apply ml-7 mb-2 lg:mb-4;
    }

    li {
      @apply pl-2;
    }

    .wp-block-image {
      @apply my-6 lg:my-10;
    }
  }
</style>

<script>
  const postContent = document.querySelector('.content-area');
  const codeBlocks = postContent?.querySelectorAll('.wp-block-code code');

  if ( codeBlocks && codeBlocks.length > 0) {
    const { default:hljs } = await import("highlight.js");

    codeBlocks.forEach((code) => {
      hljs.highlightElement(code);
    });
  }
</script>

<div class="content-area" set:html={content}/>
