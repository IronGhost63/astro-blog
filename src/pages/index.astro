---
import { getCollection } from 'astro:content';
import dayjs from "dayjs"
import App from "@layout/App.astro";
import HomePostGrid from "@component/HomePostGrid.astro";
import { POSTS_PER_PAGE } from "@src/consts";

const posts = await getCollection('web');

posts.sort((a, b) => dayjs(b.data.datetime).diff(dayjs(a.data.datetime)));

const firstPost = posts[0];
const morePosts = posts.slice(1, (POSTS_PER_PAGE));

console.log(morePosts.length)
---
<style>
	@reference "../styles/app.css";
</style>

<App>
	<HomePostGrid firstPost={firstPost} morePosts={morePosts} totalPosts={posts.length}/>
</App>
